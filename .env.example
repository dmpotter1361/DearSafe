# Copy this to .env before running `docker compose up`. NEVER commit your real .env.

# Secret used to sign session cookies. Generate a long random string, e.g.:
#   openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Host/container port. Optional; defaults to 3600.
PORT=3600

# Set to true ONLY when the app is served over HTTPS (e.g. the caddy profile).
# Leave false for plain-HTTP access, or logins won't work.
COOKIE_SECURE=false

# Domain for the optional HTTPS (caddy) profile. Caddy auto-issues a Let's Encrypt
# certificate for this name. Requires ports 80/443 reachable from the internet.
DOMAIN=your-domain.example

# Public base URL of the app (used for links + any OAuth redirects).
#   Local/plain HTTP:  http://localhost:3600
#   Behind HTTPS:      https://your-domain.example
APP_BASE_URL=http://localhost:3600

# --- Development mode (TEMPORARY, for you + a tester) ---
# true  -> easy shared login, no auto-lock, seed data, "DEV MODE" banner.
#          Encryption stays ON but trivially unlockable. NEVER put real entries here.
# unset/false -> full security (production default).
DEARSAFE_DEV=false

# --- Google Drive (optional) — stores small encrypted VIDEO clips in YOUR Drive ---
# Create OAuth credentials at console.cloud.google.com -> APIs & Services ->
# Credentials -> OAuth client ID -> Web application. Add this authorized redirect URI:
#   <APP_BASE_URL>/api/drive/callback
# Leave blank to keep all media local (photos/audio are always local).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
